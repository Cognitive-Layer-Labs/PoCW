# -----------------------------------------------------------------------------
# PoCW — environment template
# Copy to .env and fill all values before running.
# -----------------------------------------------------------------------------

# ── LLM provider ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=""

# ── Oracle signer ─────────────────────────────────────────────────────────────
# Private key the oracle uses to sign attestations (EIP-191).
# Local dev: use Hardhat account #1 key (0x59c6...) — deploy script sets this as oracle.
# Testnet: generate a dedicated wallet and fund it.
ORACLE_PRIVATE_KEY=""
# Ethereum address derived from ORACLE_PRIVATE_KEY.
ORACLE_ADDRESS=""

# ── Contract deployment (Hardhat / Hardhat scripts) ──────────────────────────
# Deployer private key used by scripts/deploy.ts.
# Local dev: use Hardhat account #0 key (0xac09...).
PRIVATE_KEY=""
BASE_SEPOLIA_RPC_URL=""

# ── KAL token ────────────────────────────────────────────────────────────────
# ERC-20 KAL contract address — set after running npm run deploy:local or deploy:base-sepolia.
# Local dev: copy kalAddress from deployments/localhost.json after each deploy.
KAL_ADDRESS=""
# RPC endpoint the oracle uses to send KAL mint transactions.
# Local dev (Docker):  http://host.docker.internal:8545
# Local dev (native):  http://127.0.0.1:8545
# Testnet:             same value as BASE_SEPOLIA_RPC_URL
RPC_URL=""

# ── KalPaywall contract ───────────────────────────────────────────────────────
# Deployed by scripts/deploy.ts — copy paywallAddress from deployments/<network>.json.
PAYWALL_ADDRESS=""

# ── SBT contract ─────────────────────────────────────────────────────────────
# Deployed by scripts/deploy.ts — copy sbtAddress from deployments/<network>.json.
SBT_ADDRESS=""

# ── Admin wallet ─────────────────────────────────────────────────────────────
# Ethereum address of the PoCW deployer wallet.
# The /admin page and /api/admin/* routes use this for the cosmetic access check.
# Leave empty in local dev (open access).
ADMIN_ADDRESS=""

# ── Oracle HTTP API ───────────────────────────────────────────────────────────
# Allowed browser origin for CORS (your frontend URL).
# Local dev: http://localhost:3002  |  Production: https://your-frontend.com
CORS_ORIGIN=""
# Bearer token protecting all /api routes.
# Leave empty in local dev (no auth). Required in production.
POCW_API_KEY=""
PORT=3000

# ── Data stores ───────────────────────────────────────────────────────────────
# When oracle runs inside Docker, docker-compose.yml overrides these with
# the internal service hostnames (falkordb / redis). These values are only
# used when running the oracle natively (outside Docker).
FALKORDB_HOST="localhost"
FALKORDB_PORT=6379
FALKORDB_GRAPH="pocw"
REDIS_URL="redis://localhost:6380/1"

# ── Production / VPS (docker-compose.vps.yml only) ───────────────────────────
ORACLE_DOMAIN=""
ACME_EMAIL=""
# Redis password — must match the value used in docker-compose.vps.yml.
REDIS_PASSWORD=""
