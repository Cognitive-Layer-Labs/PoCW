# -----------------------------------------------------------------------------
# PoCW — environment template
# Copy to .env and fill all values before running.
# -----------------------------------------------------------------------------

# ── LLM provider ─────────────────────────────────────────────────────────────
# OpenRouter API key used by question generation and grading.
OPENROUTER_API_KEY=""

# ── Oracle signer ─────────────────────────────────────────────────────────────
# Private key the oracle uses to sign attestations (EIP-191).
ORACLE_PRIVATE_KEY=""
# Ethereum address derived from ORACLE_PRIVATE_KEY.
# Must match exactly — used as the oracle address in PoCW_Controller.deploy().
ORACLE_ADDRESS=""

# ── Contract deployment (Hardhat) ─────────────────────────────────────────────
# Deployer private key used by scripts/deploy.ts.
PRIVATE_KEY=""
# Base Sepolia RPC endpoint for testnet deployment.
BASE_SEPOLIA_RPC_URL=""

# ── Oracle HTTP API ───────────────────────────────────────────────────────────
# Allowed browser origin for CORS (your frontend URL).
# Local dev: http://localhost:3001  |  Production: https://your-frontend.com
CORS_ORIGIN=""
# Optional bearer token for /api routes. Leave empty to disable auth.
POCW_API_KEY=""
# HTTP port the oracle listens on.
PORT="3000"

# ── Data stores ───────────────────────────────────────────────────────────────
FALKORDB_HOST="localhost"
FALKORDB_PORT="6379"
FALKORDB_GRAPH="pocw"
# Only needed if your FalkorDB instance requires auth.
FALKORDB_PASSWORD=""
# Redis password — must match the value used in docker-compose.vps.yml.
REDIS_PASSWORD=""
# Only needed when running oracle-service directly outside docker compose.
REDIS_URL=""

# ── Production / VPS (docker-compose.vps.yml only) ───────────────────────────
# Public domain served by nginx + Let's Encrypt.
ORACLE_DOMAIN=""
# Email for Let's Encrypt registration and renewal notices.
ACME_EMAIL=""
