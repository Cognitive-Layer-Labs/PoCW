# -----------------------------------------------------------------------------
# PoCW production environment template
# Fill all required values before deployment.
# -----------------------------------------------------------------------------

# Domain and TLS (Nginx + Certbot)
# Public domain that will serve the oracle API.
ORACLE_DOMAIN=""
# Email used by Let's Encrypt for registration and renewal notices.
ACME_EMAIL=""

# Oracle HTTP API behavior
# Allowed browser origin for CORS, usually your frontend URL.
CORS_ORIGIN=""
# Bearer token required by /api routes when set.
POCW_API_KEY=""
# Oracle API listen port.
PORT="3000"

# LLM provider (OpenRouter)
# Used by question generation and grading calls.
OPENROUTER_API_KEY=""

# Base Sepolia deployment and signing wallets
# Base Sepolia RPC endpoint used by Hardhat deployment scripts.
BASE_SEPOLIA_RPC_URL=""
# Deployer private key used by scripts/deploy.ts.
PRIVATE_KEY=""
# Oracle signer private key used by oracle-service/src/services/signer.ts.
ORACLE_PRIVATE_KEY=""
# Oracle signer address registered in PoCW_Controller deploy.
# This must match the address derived from ORACLE_PRIVATE_KEY.
ORACLE_ADDRESS=""

# Data store configuration
# FalkorDB connection used for knowledge graph storage.
FALKORDB_HOST="localhost"
FALKORDB_PORT="6379"
# Optional: only if your FalkorDB instance requires auth.
FALKORDB_PASSWORD=""
FALKORDB_GRAPH="pocw"
# Password for Redis service (must match docker-compose.vps.yml service password).
REDIS_PASSWORD=""
# Optional: used when running oracle-service directly outside docker compose.
REDIS_URL=""
